{
  "name": "@openade/runtime-node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck",
    "check:no-any": "node ../../scripts/check-no-explicit-any.mjs --self-test .",
    "typecheck": "npm run check:no-any && ../electron/node_modules/.bin/tsgo --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./src": "./src/index.ts",
    "./src/*": "./src/*"
  },
  "bin": {
    "runtime-node": "./src/cli.ts"
  },
  "dependencies": {
    "ws": "^8.21.0",
    "yjs": "^13.6.30"
  }
}
