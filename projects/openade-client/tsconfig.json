{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["ESNext", "DOM"],
    "paths": {
      "vitest": ["../electron/node_modules/vitest/dist/index.d.ts"],
      "yjs": ["../web/node_modules/yjs/dist/src/index.d.ts"]
    },
    "types": ["node"],
    "typeRoots": ["../electron/node_modules/@types"]
  },
  "include": ["src/**/*", "../runtime-client/src/**/*", "../runtime-protocol/src/**/*", "../shared/companion/src/**/*"],
  "exclude": ["../runtime-client/src/**/*.test.ts", "../runtime-protocol/src/**/*.test.ts"]
}
