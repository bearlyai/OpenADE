{
  "name": "@openade/openade-module",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "npm run typecheck && npm run test",
    "test": "../electron/node_modules/.bin/vitest run --reporter=verbose",
    "check:no-any": "node ../../scripts/check-no-explicit-any.mjs --self-test .",
    "import:yjs:core": "node scripts/run-yjs-import-core.mjs",
    "typecheck": "npm run check:no-any && ../electron/node_modules/.bin/tsgo --noEmit"
  },
  "exports": {
    ".": "./src/index.ts",
    "./src": "./src/index.ts",
    "./src/*": "./src/*"
  },
  "dependencies": {
    "yjs": "^13.6.30"
  }
}
